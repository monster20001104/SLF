`include "../common/common64.rdlh"
addrmap beq_rxq_dfx{
    reg dfx_err{
        woclr_field dfx_err[40:0] = 0;
    };
    dfx_err dfx_err @0x0;
    reg dfx_status{
        hwsts_field dfx_status[44:0] = 0;
    };
    dfx_status dfx_status @0x40;

    reg dfx_status_qid{
        hwsts_field dfx_status_qid[31:0] = 0;
    };
    dfx_status_qid dfx_status_qid @0x48;

    reg beq2user_cnt{
        hwsts_field beq2user_cnt[31:0] = 0;
    };
    beq2user_cnt beq2user_cnt @0x100;

    reg dma_cnt{
        hwsts_field dma_cnt[23:0] = 0;
    };
    dma_cnt dma_cnt @0x108;

    reg rd_ndesc_cnt{
        hwsts_field rd_ndesc_cnt[39:0] = 0;
    };
    rd_ndesc_cnt rd_ndesc_cnt @0x110;

};
