`include "../common/common64.rdlh"
addrmap beq_desc_eng_dfx{
    reg dfx_err{
        woclr_field dfx_err[24:0] = 0;
    };
    dfx_err dfx_err @0x0;

    reg dfx_rxq_err{
        woclr_field dfx_rxq_err[4:0] = 0;
    };
    dfx_rxq_err dfx_rxq_err @0x8;

    reg dfx_txq_err{
        woclr_field dfx_txq_err[4:0] = 0;
    };
    dfx_txq_err dfx_txq_err @0x10;

    reg dfx_rd_rsp_desc_err{
        woclr_field dfx_rd_rsp_desc_err[8:0] = 0;
    };
    dfx_rd_rsp_desc_err dfx_rd_rsp_desc_err @0x18;

    reg dfx_status{
        hwsts_field dfx_status[24:0] = 0;
    };
    dfx_status dfx_status @0x40;

    reg dfx_rxq_status{
        hwsts_field dfx_rxq_status[7:0] = 0;
    };
    dfx_rxq_status dfx_rxq_status @0x48;

    reg dfx_txq_status{
        hwsts_field dfx_txq_status[7:0] = 0;
    };
    dfx_txq_status dfx_txq_status @0x50;

    reg dfx_rd_rsp_desc_status{
        hwsts_field dfx_rd_rsp_desc_status[1:0] = 0;
    };
    dfx_rd_rsp_desc_status dfx_rd_rsp_desc_status @0x58;


    reg dfx_dma_cnt{
        hwsts_field dfx_dma_cnt[15:0] = 0;
    };
    dfx_dma_cnt dfx_dma_cnt @0x100;
};