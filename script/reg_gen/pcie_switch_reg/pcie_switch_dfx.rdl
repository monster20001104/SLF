`include "../common/common.rdlh"

addrmap pcie_switch_dfx{
    reg err{
        woclr_field err[31:0] = 0;
    };
    err err @0x0;

    reg bdf{
        hwsts_field bdf[15:0] = 0;
    };
    bdf bdf @0x8;

    reg status{
        hwsts_field status[31:0] = 0;
    };
    status status @0x100;

    reg cnt1{
        woclr_field cnt1[31:0] = 0;
    }; 
    cnt1 cnt1 @0x200;

    reg cnt2{
        woclr_field cnt2[31:0] = 0;
    }; 
    cnt2 cnt2 @0x208;

    reg vd_id{
        swcfg_field vd_id[31:0] = 0xfe1b36;
    };
    vd_id vd_id @0x300;

    reg r_id{
        swcfg_field r_id[7:0] = 0;
    };
    r_id r_id @0x308;

    reg mps_s{
        swcfg_field mps_s[2:0] = 0;
    };
    mps_s mps_s @0x310;

    reg bypass{
        swcfg_field bypass[0:0] = 1;
    };
    bypass bypass @0x318;

    reg downstream_enable{
        swcfg_field downstream_enable[0:0] = 0;
    };
    downstream_enable downstream_enable @0x320;

    reg max_request{
        swcfg_field max_request[2:0] = 0x5;
    };
    max_request max_request @0x328;    

    reg link2csr{
        swcfg_field link2csr[12:0] = 0x3;
    };
    link2csr link2csr @0x330; 

    reg comclk_reg{
        swcfg_field comclk_reg[0:0] = 0x1;
    };
    comclk_reg comclk_reg @0x338; 

    reg extsy_reg{
        swcfg_field extsy_reg[0:0] = 0x0;
    };
    extsy_reg extsy_reg @0x340; 

    reg max_pload{
        swcfg_field max_pload[2:0] = 0x0;
    };
    max_pload max_pload @0x348; 

    reg secbus7_0{
        swcfg_field secbus7_0[7:0] = 0x0;
    };
    secbus7_0 secbus7_0 @0x350; 

    reg linkcsr_bit0{
        swcfg_field linkcsr_bit0[0:0] = 0x0;
    };
    linkcsr_bit0 linkcsr_bit0 @0x358; 


};