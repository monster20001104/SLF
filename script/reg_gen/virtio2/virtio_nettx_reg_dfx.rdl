`include "../common/common64.rdlh"
addrmap virtio_nettx_reg_dfx{
    reg dfx_err{
        woclr_field dfx_err[63:0] = 0;
    };
    dfx_err dfx_err0 @0x0;
    dfx_err dfx_err1 @0x8;
    dfx_err dfx_err2 @0x10;


    reg dfx_status{
        hwsts_field dfx_status[63:0] = 0;
    };
    dfx_status dfx_status0 @0x100;
    dfx_status dfx_status1 @0x108;
    dfx_status dfx_status2 @0x110;

    reg dfx_cnt{
        hwsts_field dfx_cnt[63:0] = 0;
    };
    dfx_cnt dma_req_rate   @0x200;
    dfx_cnt dma_rsp_rate   @0x208;
    dfx_cnt tso_rate       @0x210;
    dfx_cnt rd_issued_cnt  @0x218;
    dfx_cnt rd_rsp_cnt     @0x220;


    reg dfx_threshold{
        swmod_field dfx_threshold[31:0] = 0;
    };
    dfx_threshold dfx_threshold0 @0x400;

  
};